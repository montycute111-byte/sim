rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid && isValidUserDoc();

      function isValidUserDoc() {
        return request.resource.data.keys().hasOnly([
          'email',
          'createdAt',
          'updatedAt',
          'gameState'
        ])
        && request.resource.data.email is string
        && request.resource.data.gameState is map;
      }
    }
  }
}
